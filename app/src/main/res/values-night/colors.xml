<?xml version="1.0" encoding="utf-8"?>
<!--
  Driftway — AMOLED night palette. True-black surfaces (#000) with a single ELECTRIC BLUE
  accent that glows on black. No purple/rainbow roles: secondary/tertiary stay in the blue
  family so exactly one hue carries the brand (active / focus / primary / progress).
-->
<resources>
    <!-- Electric-blue accent, brightened so it pops on true black -->
    <color name="theme_primary">#4D9BFF</color>
    <color name="theme_on_primary">#00224C</color>
    <color name="theme_primary_container">#0A4FD0</color>
    <color name="theme_on_primary_container">#DCE7FF</color>
    <!-- Secondary: muted blue-grey (supporting chips/containers), same hue family -->
    <color name="theme_secondary">#A9C2EB</color>
    <color name="theme_on_secondary">#102744</color>
    <color name="theme_secondary_container">#28405F</color>
    <color name="theme_on_secondary_container">#D5E3FF</color>
    <!-- Tertiary kept in the blue family (was purple) -->
    <color name="theme_tertiary">#7FD0FF</color>
    <color name="theme_on_tertiary">#00344C</color>
    <color name="theme_tertiary_container">#134A66</color>
    <color name="theme_on_tertiary_container">#CDEBFF</color>
    <color name="theme_error">#FFB4AB</color>
    <color name="theme_on_error">#690005</color>
    <color name="theme_error_container">#93000A</color>
    <color name="theme_on_error_container">#FFDAD6</color>
